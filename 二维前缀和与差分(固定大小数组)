#include<bits/stdc++.h>
using namespace std;

void input(int *s,int a,int b){
	cout<<endl;
	for(int i=1;i<=a;i++){
		for(int j=1;j<=b;j++){
		   cout<<*(s+i*(b+1)+j)<<" ";
	   }
	   cout<<endl;
	}
	cout<<endl;
}

int main(){
	int a[7][9]={0},s[7][9]={0};   //6行8列数据,记得先全初始化为0
	for(int i=1;i<=6;i++){         //用二维[n][m]vector,只需vector<vector<int>>s(n+1,vector<int>(m+1,0))
		for(int j=1;j<=8;j++){
			cin>>a[i][j];
		}
	}
	for(int i=1;i<=6;i++){
		for(int j=1;j<=8;j++){
			s[i][j]=a[i][j]+s[i-1][j]+s[i][j-1]-s[i-1][j-1];   //二维前缀和的公式
		}
	}
	int x1=2,y1=3,x2=5,y2=7,sum=0;    //求2行3列到5行7列这个矩阵里数字的和
	sum=s[x2][y2]-s[x1-1][y2]-s[x2][y1-1]+s[x1-1][y1-1];   //求和公式,用前缀和数组数据,O(1)复杂度,适合大量求和用
	input(&a[0][0],6,8);input(&s[0][0],6,8);
	cout<<sum;
	return 0;
}
