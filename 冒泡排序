#include <iostream>
using namespace std;
void bubble(int n,int a[]){
	for(int i=0;i<n-1;i++){
		for(int j=0;j<n-i-1;j++){
			if(a[j]>a[j+1]){
				int temp=a[j];
				a[j]=a[j+1];
				a[j+1]=temp;
			}
		}
	}
}
int main(){
    int n;cin>>n;
    int s[n];
    for(int i=0;i<n;i++){
    	cin>>s[i];
	}
	bubble(n,s); //s是数组开头
	for(int i=0;i<n;i++){
    	cout<<s[i]<<" ";
	}
	return 0;
}
