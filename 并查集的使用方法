#include<bits/stdc++.h>
using namespace std;
const int MAXN=100;  //数组大小,可以自定义
int fa[MAXN];   //父节点数组

void init(){
    for(int i=0;i<MAXN;i++){   //初始化函数,每个数的父节点是自己
        fa[i]=i;
    }
}

int find(int x){
    if(fa[x]==x) return x;
    return fa[x]=find(fa[x]);   //寻找函数,查找根节点+路径压缩
}

void unite(int x,int y){   //合并集合
    x=find(x);
    y=find(y);
    if(x!=y){
       fa[y]=x;
    }
}

bool isSame(int x,int y) {   //判断两个数是否在同一个集合
    return find(x)==find(y);
}

int main(){
    init();   //初始化并查集
    for (int i=2;i<=9;i++) {
        unite(1,i);
    }
    for (int i=11; i<=99;i++) {
        unite(10,i);
    }
    return 0;
}
